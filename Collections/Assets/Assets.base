filters:
  and:
    - base == link("Assets.base")
    - Status != "Archived"
properties:
  file.name:
    displayName: Name
  Period Owned:
    displayName: Period Owned
  Status:
    displayName: Status
  Notes:
    displayName: Notes
  Market Value:
    displayName: Market Value
views:
  - type: table
    name: Table View
    order:
      - file.name
      - Period Owned
      - Status
      - Notes
      - Market Value
    columnSize:
      note.Status: 157
