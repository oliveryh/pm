# Estate Agents

filters:
  and:
    - note["base"] == link("Estate Agents.base")
properties:
  file.name:
    displayName: Name
  Notes:
    displayName: Notes
  Appears on Rightmove:
    displayName: Appears on Rightmove
  Registered:
    displayName: Registered
  Alert Added:
    displayName: Alert Added
  Search URL:
    displayName: Search URL
views:
  - type: table
    name: Table View
    order:
      - file.name
      - Notes
      - Appears on Rightmove
      - Registered
      - Alert Added
      - Search URL
