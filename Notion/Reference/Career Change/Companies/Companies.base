# Companies

filters:
  and:
    - note["base"] == link("Companies.base")
properties:
  file.name:
    displayName: Name
  Working Style:
    displayName: Working Style
  Contact:
    displayName: Contact
  Location:
    displayName: Location
  Careers URL:
    displayName: Careers URL
views:
  - type: table
    name: Table View
    order:
      - file.name
      - Working Style
      - Contact
      - Location
      - Careers URL
